<div data-controller="toast"
     class="pointer-events-auto flex items-center gap-3 bg-white border border-gray-100 shadow-2xl shadow-indigo-100 rounded-2xl px-5 py-4 min-w-[320px] transition-all duration-500 transform translate-x-0"
     style="animation: toast-in 0.5s cubic-bezier(0.16, 1, 0.3, 1)">
  
  <%# Icon based on type %>
  <div class="w-10 h-10 rounded-xl flex items-center justify-center <%= type == 'notice' ? 'bg-green-50 text-green-600' : 'bg-indigo-50 text-indigo-600' %>">
    <% if type == 'notice' %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    <% else %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    <% end %>
  </div>

  <div class="flex-1">
    <p class="text-sm font-bold text-gray-900"><%= message %></p>
    <p class="text-[10px] text-gray-400 font-medium tracking-tight uppercase">Notification</p>
  </div>

  <button data-action="click->toast#close" class="text-gray-300 hover:text-gray-900 transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
</div>

<style>
@keyframes toast-in {
  from { opacity: 0; transform: translateX(100%); }
  to { opacity: 1; transform: translateX(0); }
}
</style>
