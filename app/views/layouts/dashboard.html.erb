<!DOCTYPE html>
<html>
  <head>
    <title>Tokko Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
  </head>

  <body class="bg-gray-50/50 flex">
    <%= render "layouts/flash" %>
    
    <%# Sidebar %>
    <aside class="w-64 h-screen sticky top-0 bg-gray-900 flex flex-col shrink-0">
      <%# Brand %>
      <div class="p-6">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center text-white font-black">T</div>
          <span class="text-white font-bold tracking-tight text-lg">Tokko<span class="text-indigo-400">.</span></span>
        </div>
      </div>

      <%# Navigation %>
      <nav class="flex-1 px-4 space-y-1 mt-4">
        <%= link_to dashboard_root_path, 
            class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{controller_name == 'home' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span class="text-sm font-semibold">Overview</span>
        <% end %>

        <%= link_to dashboard_products_path, 
            class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{controller_name == 'products' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
          </svg>
          <span class="text-sm font-semibold">Products</span>
        <% end %>

        <%= link_to dashboard_collections_path, 
            class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{controller_name == 'collections' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span class="text-sm font-semibold">Collections</span>
        <% end %>

        <%= link_to dashboard_categories_path,
            class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{controller_name == 'categories' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
          </svg>
          <span class="text-sm font-semibold">Categories</span>
        <% end %>

        <%= link_to dashboard_filter_groups_path,
            class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{controller_name == 'filter_groups' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
          </svg>
          <span class="text-sm font-semibold">Filters</span>
        <% end %>

        <% inventory_active = %w[inventories inventory_movements].include?(controller_name) %>
        <div class="space-y-0.5">
          <%= link_to dashboard_inventory_path,
              class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{inventory_active ? 'text-white' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            <span class="text-sm font-semibold">Inventory</span>
          <% end %>

          <% if inventory_active %>
            <div class="ml-9 space-y-0.5">
              <%= link_to "Stock Levels", dashboard_inventory_path,
                  class: "block text-xs font-semibold px-3 py-1.5 rounded-lg transition-all #{controller_name == 'inventories' ? 'text-white bg-white/10' : 'text-gray-500 hover:text-white hover:bg-white/5'}" %>
              <%= link_to "Movement History", dashboard_inventory_movements_path,
                  class: "block text-xs font-semibold px-3 py-1.5 rounded-lg transition-all #{controller_name == 'inventory_movements' ? 'text-white bg-white/10' : 'text-gray-500 hover:text-white hover:bg-white/5'}" %>
            </div>
          <% end %>
        </div>

        <%= link_to dashboard_orders_path, 
            class: "flex items-center justify-between px-4 py-3 rounded-xl transition-all #{controller_name == 'orders' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span class="text-sm font-semibold">Orders</span>
          </div>
          <% order_count = Order.where(status: :pending).count %>
          <% if order_count > 0 %>
            <span class="bg-indigo-400 text-indigo-900 text-[10px] font-black px-2 py-0.5 rounded-md"><%= order_count %></span>
          <% end %>
        <% end %>

        <% if Current.user.owner? %>
          <%= link_to dashboard_users_path,
              class: "flex items-center gap-3 px-4 py-3 rounded-xl transition-all #{controller_name == 'users' ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-900/20' : 'text-gray-400 hover:bg-white/5 hover:text-white'}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <span class="text-sm font-semibold">Users</span>
          <% end %>
        <% end %>

        <div class="pt-4 pb-2">
          <p class="px-4 text-[10px] font-bold text-gray-500 uppercase tracking-widest">Storefront</p>
        </div>

        <%= link_to root_path, target: "_blank",
            class: "flex items-center gap-3 px-4 py-3 rounded-xl text-gray-400 hover:bg-white/5 hover:text-white transition-all" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span class="text-sm font-semibold">View Store</span>
        <% end %>
      </nav>

      <%# User Profile %>
      <div class="p-4 border-t border-white/5">
        <div class="flex items-center gap-3 p-3 bg-white/5 rounded-2xl">
          <div class="w-9 h-9 rounded-xl bg-indigo-500 flex items-center justify-center text-white font-bold text-xs uppercase">
            <%= Current.user.email_address[0..1] %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-bold text-white truncate"><%= Current.user.email_address %></p>
            <p class="text-[10px] text-gray-500 font-medium capitalize"><%= Current.user.role %></p>
          </div>
          <%= button_to session_path, method: :delete, class: "text-gray-500 hover:text-red-400 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
          <% end %>
        </div>
      </div>
    </aside>

    <%# Main Content Area %>
    <main class="flex-1 min-w-0">
      <%= yield %>
    </main>

  </body>
</html>
