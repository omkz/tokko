<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Tokko Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
  </head>

  <body class="bg-white">
    <%= render "layouts/flash" %>
    <%# Storefront Header %>
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <%# Logo %>
        <%= link_to root_path, class: "flex items-center gap-2.5 group" do %>
          <div class="w-9 h-9 bg-gray-900 rounded-xl flex items-center justify-center text-white font-black group-hover:scale-105 transition-transform">T</div>
          <span class="text-xl font-bold tracking-tight text-gray-900">Tokko<span class="text-indigo-600">.</span></span>
        <% end %>

        <%# Nav %>
        <nav class="hidden md:flex items-center gap-8">
          <%= link_to "All Products", root_path, class: "text-sm font-semibold text-gray-600 hover:text-gray-900 transition-colors" %>
          <% @nav_categories&.each do |category| %>
            <%= link_to category.name, category_path(category), class: "text-sm font-semibold text-gray-600 hover:text-gray-900 transition-colors" %>
          <% end %>
        </nav>

        <%# Actions %>
        <div class="flex items-center gap-5">
          <%# Search Form %>
          <%= form_with url: root_path, method: :get, class: "hidden lg:flex items-center relative group" do |f| %>
            <%= f.text_field :q, value: params[:q], placeholder: "Search products...", 
                class: "bg-gray-100 border-none rounded-full pl-10 pr-4 py-2 text-sm w-48 focus:w-64 focus:ring-2 focus:ring-indigo-500 transition-all outline-none" %>
            <div class="absolute left-3.5 text-gray-400 group-focus-within:text-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <% if params[:q].present? %>
              <%= link_to root_path, class: "absolute right-3 text-gray-400 hover:text-red-500" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
              <% end %>
            <% end %>
          <% end %>

          <%# Cart Icon %>
          <%= link_to cart_path, class: "relative group p-2 rounded-full hover:bg-gray-50 transition-all" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-700 group-hover:text-gray-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span id="cart-count" class="absolute -top-0.5 -right-0.5 bg-indigo-600 text-white text-[10px] font-black w-5 h-5 flex items-center justify-center rounded-full border-2 border-white shadow-sm <%= 'hidden' if cart_count == 0 %>">
              <%= cart_count %>
            </span>
          <% end %>

          <%# Account %>
          <% if authenticated? %>
            <%= link_to dashboard_root_path, class: "text-sm font-bold text-gray-900 bg-gray-100 px-4 py-2 rounded-xl hover:bg-gray-200 transition-colors" do %>
              Dashboard
            <% end %>
          <% else %>
            <%= link_to new_session_path, class: "text-sm font-bold text-gray-900" do %>
              Login
            <% end %>
          <% end %>
        </div>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>
  </body>
</html>
