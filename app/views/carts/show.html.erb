<div class="bg-gray-50/50 min-h-screen pb-24">
  <div class="max-w-4xl mx-auto px-6 py-12">
    
    <div class="flex items-center justify-between mb-10">
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Shopping Bag</h1>
      <span class="text-sm font-medium text-gray-500"><%= cart_count %> items</span>
    </div>

    <% if @cart_items.any? %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <%# Items List %>
        <div class="lg:col-span-2 space-y-4">
          <% @cart_items.each do |item| %>
            <div class="bg-white p-5 rounded-3xl border border-gray-100 shadow-sm flex gap-6">
              <%# Image %>
              <div class="w-24 h-24 rounded-2xl bg-gray-50 border border-gray-100 overflow-hidden shrink-0">
                <% if item[:variant].product.images.attached? %>
                  <%= image_tag item[:variant].product.images.first.variant(resize_to_limit: [200, 200]), class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full flex items-center justify-center text-2xl opacity-20">📦</div>
                <% end %>
              </div>

              <%# Details %>
              <div class="flex-1 flex flex-col justify-between">
                <div>
                  <div class="flex items-start justify-between">
                    <h3 class="font-bold text-gray-900"><%= item[:variant].product.name %></h3>
                    <p class="font-bold text-gray-900 text-sm">Rp <%= number_with_delimiter(item[:variant].price.to_i) %></p>
                  </div>
                  <p class="text-xs text-gray-400 mt-1"><%= item[:variant].option_text %></p>
                </div>

                <div class="flex items-center justify-between mt-4">
                  <%# Quantity Controls %>
                  <div class="flex items-center border border-gray-100 rounded-xl px-2 py-1 bg-gray-50">
                    <%= button_to cart_path(variant_id: item[:variant].id, quantity: item[:quantity] - 1), method: :patch, class: "p-1 text-gray-400 hover:text-gray-900 transition-colors" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" /></svg>
                    <% end %>
                    <span class="px-3 text-xs font-bold text-gray-700"><%= item[:quantity] %></span>
                    <%= button_to cart_path(variant_id: item[:variant].id, quantity: item[:quantity] + 1), method: :patch, class: "p-1 text-gray-400 hover:text-gray-900 transition-colors" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    <% end %>
                  </div>

                  <%= button_to cart_path(variant_id: item[:variant].id, quantity: 0), method: :patch, class: "text-xs font-bold text-red-400 hover:text-red-600 transition-colors" do %>
                    Remove
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>

          <div class="pt-4">
            <%= link_to root_path, class: "text-sm font-bold text-indigo-600 hover:text-indigo-800 transition-colors flex items-center gap-2" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
              Continue Shopping
            <% end %>
          </div>
        </div>

        <%# Summary Sidebar %>
        <div class="space-y-6">
          <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
            <h2 class="text-sm font-black text-gray-900 uppercase tracking-widest mb-6">Order Summary</h2>
            
            <div class="space-y-4 text-sm font-medium">
              <div class="flex justify-between text-gray-500">
                <span>Subtotal</span>
                <span class="text-gray-900">Rp <%= number_with_delimiter(@total_price) %></span>
              </div>
              <div class="flex justify-between text-gray-500">
                <span>Shipping</span>
                <span class="text-green-600">Free</span>
              </div>
              <div class="border-t border-gray-100 pt-4 flex justify-between text-lg font-black text-gray-900">
                <span>Total</span>
                <span>Rp <%= number_with_delimiter(@total_price) %></span>
              </div>
            </div>

            <%= link_to new_checkout_path, class: "block w-full bg-gray-900 text-white py-4 rounded-2xl font-bold mt-8 hover:bg-gray-800 transition-all shadow-xl active:scale-95 text-center" do %>
              Proceed to Checkout
            <% end %>
          </div>

          <div class="flex items-center gap-3 px-4 py-3 bg-indigo-50 rounded-2xl border border-indigo-100">
            <span class="text-xl">✨</span>
            <p class="text-[10px] font-bold text-indigo-700 leading-tight">Checkout now and get a 5% discount on your next purchase!</p>
          </div>
        </div>
      </div>
    <% else %>
      <%# Empty Cart %>
      <div class="bg-white border-2 border-dashed border-gray-200 rounded-3xl py-24 text-center">
        <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-4xl opacity-40">🛍️</span>
        </div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">Your bag is empty</h2>
        <p class="text-gray-400 text-sm max-w-xs mx-auto mb-8">Looks like you haven't added anything to your bag yet.</p>
        <%= link_to "Browse Products", root_path, class: "inline-block bg-gray-900 text-white px-8 py-3 rounded-xl font-bold hover:bg-gray-800 transition-all shadow-lg active:scale-95" %>
      </div>
    <% if params[:debug] %>
      <pre class="mt-10 text-[10px]"><%= session[:cart].inspect %></pre>
    <% end %>
    <% end %>

  </div>
</div>
