<div class="bg-gray-50/50 min-h-screen pb-24">
  <div class="max-w-4xl mx-auto px-6 py-12">

    <%# Header %>
    <div class="flex items-center gap-4 mb-10">
      <%= link_to orders_path, class: "p-2 rounded-xl bg-white border border-gray-100 hover:border-gray-300 shadow-sm transition-all text-gray-400 hover:text-gray-700" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      <div>
        <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight">Order #<%= @order.id.to_s.rjust(5, '0') %></h1>
        <p class="text-sm text-gray-400 mt-0.5">Placed on <%= @order.created_at.strftime("%B %d, %Y at %H:%M") %></p>
      </div>
      <span class="ml-auto inline-flex items-center px-3 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-wider
        <%= case @order.status
            when 'pending'   then 'bg-yellow-50 text-yellow-700 border border-yellow-100'
            when 'paid'      then 'bg-blue-50 text-blue-700 border border-blue-100'
            when 'shipped'   then 'bg-indigo-50 text-indigo-700 border border-indigo-100'
            when 'completed' then 'bg-green-50 text-green-700 border border-green-100'
            else                  'bg-gray-50 text-gray-500 border border-gray-100'
            end %>">
        <%= @order.status.capitalize %>
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <%# Items Card %>
      <div class="md:col-span-2">
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
            <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest">Items Ordered</h2>
          </div>
          <div class="divide-y divide-gray-100">
            <% @order_items.each do |item| %>
              <div class="px-6 py-5 flex items-center gap-4">
                <div class="w-16 h-16 rounded-2xl bg-gray-50 border border-gray-100 overflow-hidden flex-shrink-0">
                  <% if item.product_variant.product.images.attached? %>
                    <%= image_tag item.product_variant.product.images.first.variant(resize_to_limit: [120, 120]), class: "w-full h-full object-cover" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-2xl opacity-20">📦</div>
                  <% end %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-gray-900 truncate"><%= item.product_variant.product.name %></p>
                  <p class="text-xs text-gray-400 mt-0.5"><%= item.product_variant.option_text %></p>
                  <p class="text-xs text-gray-500 mt-1">Qty: <%= item.quantity %></p>
                </div>
                <div class="text-right flex-shrink-0">
                  <p class="text-sm font-bold text-gray-900">Rp <%= number_with_delimiter((item.unit_price * item.quantity).to_i) %></p>
                  <p class="text-xs text-gray-400 mt-0.5">Rp <%= number_with_delimiter(item.unit_price.to_i) %> each</p>
                </div>
              </div>
            <% end %>
          </div>
          <div class="px-6 py-4 bg-gray-50/50 border-t border-gray-100 flex justify-between items-center">
            <span class="text-sm font-semibold text-gray-500">Order Total</span>
            <span class="text-xl font-black text-gray-900">Rp <%= number_with_delimiter(@order.total_price.to_i) %></span>
          </div>
        </div>
      </div>

      <%# Sidebar %>
      <div class="space-y-4">
        <%# Shipping Info %>
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
          <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-4">Shipping To</h2>
          <div class="space-y-3">
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Name</p>
              <p class="text-sm font-semibold text-gray-900 mt-0.5"><%= @order.customer_name %></p>
            </div>
            <% if @order.customer_phone.present? %>
              <div>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Phone</p>
                <p class="text-sm text-gray-700 mt-0.5"><%= @order.customer_phone %></p>
              </div>
            <% end %>
            <div>
              <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Address</p>
              <p class="text-sm text-gray-600 mt-0.5 leading-relaxed"><%= @order.shipping_address %></p>
            </div>
          </div>
        </div>

        <%# Need help %>
        <div class="bg-indigo-50 rounded-3xl border border-indigo-100 p-6">
          <h3 class="text-xs font-bold text-indigo-900 uppercase tracking-widest mb-2">Need Help?</h3>
          <p class="text-xs text-indigo-700 leading-relaxed">Have a question about your order? Contact our support team and we'll get back to you within 24 hours.</p>
          <a href="#" class="inline-block mt-4 text-xs font-bold text-indigo-600 hover:text-indigo-800 transition-colors">Contact Support &rarr;</a>
        </div>
      </div>

    </div>
  </div>
</div>
