<div class="bg-gray-50/50 min-h-screen pb-24">
  <div class="max-w-4xl mx-auto px-6 py-12">

    <div class="mb-10">
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">My Orders</h1>
      <p class="text-sm text-gray-500 mt-1">Track and review your purchases.</p>
    </div>

    <% if @orders.any? %>
      <div class="space-y-4">
        <% @orders.each do |order| %>
          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-center gap-5">
              <div class="w-12 h-12 bg-gray-50 rounded-2xl border border-gray-100 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-black text-gray-900">Order #<%= order.id.to_s.rjust(5, '0') %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= order.created_at.strftime("%B %d, %Y") %></p>
              </div>
            </div>

            <div class="flex items-center gap-6 sm:gap-10">
              <div class="text-center">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Items</p>
                <p class="text-sm font-bold text-gray-900 mt-1"><%= order.order_items.size %></p>
              </div>
              <div class="text-center">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Total</p>
                <p class="text-sm font-bold text-gray-900 mt-1">Rp <%= number_with_delimiter(order.total_price.to_i) %></p>
              </div>
              <div class="text-center">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Status</p>
                <span class="inline-flex mt-1 items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                  <%= case order.status
                      when 'pending'   then 'bg-yellow-50 text-yellow-700 border border-yellow-100'
                      when 'paid'      then 'bg-blue-50 text-blue-700 border border-blue-100'
                      when 'shipped'   then 'bg-indigo-50 text-indigo-700 border border-indigo-100'
                      when 'completed' then 'bg-green-50 text-green-700 border border-green-100'
                      else                  'bg-gray-50 text-gray-500 border border-gray-100'
                      end %>">
                  <%= order.status.capitalize %>
                </span>
              </div>
              <%= link_to order_path(order), class: "text-sm font-bold text-indigo-600 hover:text-indigo-800 transition-colors whitespace-nowrap" do %>
                View &rarr;
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-12 flex justify-center">
        <div class="pagy">
          <%== @pagy.series_nav %>
        </div>
      </div>
    <% else %>
      <div class="bg-white border-2 border-dashed border-gray-200 rounded-3xl py-24 text-center">
        <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-gray-900 mb-2">No orders yet</h2>
        <p class="text-gray-400 text-sm max-w-xs mx-auto mb-8">Your completed purchases will appear here.</p>
        <%= link_to "Start Shopping", root_path, class: "inline-block bg-gray-900 text-white px-8 py-3 rounded-xl font-bold hover:bg-gray-800 transition-all shadow-lg active:scale-95" %>
      </div>
    <% end %>

  </div>
</div>
