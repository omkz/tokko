<% content_for :title, "Sign In" %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-sm">

    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-block text-2xl font-black text-gray-900 tracking-tight mb-6" do %>
        Tokko
      <% end %>
      <h1 class="text-2xl font-bold text-gray-900">Sign in</h1>
      <p class="text-gray-500 text-sm mt-2">We'll send a login link to your email.</p>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
      <%= form_with url: magic_link_path, method: :post do |f| %>
        <div class="mb-6">
          <%= f.label :email_address, "Email address", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.email_field :email_address, required: true, autofocus: true,
              placeholder: "you@example.com",
              class: "w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition-all" %>
        </div>

        <%= f.submit "Send login link",
            class: "w-full bg-gray-900 text-white py-3.5 rounded-xl font-bold hover:bg-gray-800 transition-all shadow-lg active:scale-95 cursor-pointer" %>
      <% end %>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      Admin? <%= link_to "Sign in with password", new_session_path, class: "text-gray-600 font-semibold hover:underline" %>
    </p>

  </div>
</div>
