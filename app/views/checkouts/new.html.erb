<div class="bg-gray-50/50 min-h-screen pb-24">
  <div class="max-w-5xl mx-auto px-6 py-12">
    
    <div class="flex items-center gap-4 mb-10">
      <%= link_to cart_path, class: "text-gray-400 hover:text-gray-900 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Checkout</h1>
    </div>

    <%= form_with model: @order, url: checkout_path, class: "grid grid-cols-1 lg:grid-cols-3 gap-12", data: { turbo: false, controller: "coupon", coupon_validate_url_value: validate_coupon_path } do |f| %>
      <%= hidden_field_tag "order[coupon_code]", "", data: { coupon_target: "couponCode" } %>
      <%# Left: Shipping Details %>
      <div class="lg:col-span-2 space-y-8">

        <% if @order.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-2xl px-6 py-4">
            <p class="text-sm font-bold text-red-700 mb-1">Please fix the following errors:</p>
            <ul class="list-disc list-inside space-y-0.5">
              <% @order.errors.full_messages.each do |msg| %>
                <li class="text-sm text-red-600"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
          <h2 class="text-sm font-black text-gray-900 uppercase tracking-widest mb-8 flex items-center gap-3">
            <span class="w-6 h-6 bg-gray-900 text-white rounded-full flex items-center justify-center text-[10px]">1</span>
            Contact Information
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="md:col-span-2">
              <%= f.label :customer_name, "Full Name", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
              <%= f.text_field :customer_name, placeholder: "e.g. John Doe", required: true,
                  class: "w-full rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition #{@order.errors[:customer_name].any? ? 'border-2 border-red-400 bg-red-50' : 'border border-gray-200'}" %>
              <% if @order.errors[:customer_name].any? %>
                <p class="text-xs text-red-500 mt-1 font-medium"><%= @order.errors[:customer_name].first %></p>
              <% end %>
            </div>
            <div>
              <%= f.label :customer_email, "Email Address", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
              <%= f.email_field :customer_email, placeholder: "john@example.com", required: true,
                  class: "w-full rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition #{@order.errors[:customer_email].any? ? 'border-2 border-red-400 bg-red-50' : 'border border-gray-200'}" %>
              <% if @order.errors[:customer_email].any? %>
                <p class="text-xs text-red-500 mt-1 font-medium"><%= @order.errors[:customer_email].first %></p>
              <% end %>
            </div>
            <div>
              <%= f.label :customer_phone, "Phone Number", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
              <%= f.text_field :customer_phone, placeholder: "0812...",
                  class: "w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition" %>
            </div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
          <h2 class="text-sm font-black text-gray-900 uppercase tracking-widest mb-8 flex items-center gap-3">
            <span class="w-6 h-6 bg-gray-900 text-white rounded-full flex items-center justify-center text-[10px]">2</span>
            Shipping Address
          </h2>

          <% if @saved_addresses.any? %>
            <div data-controller="address-selector">
              <%# Hidden field that carries the final value %>
              <%= f.hidden_field :shipping_address,
                    value: @saved_addresses.find(&:is_default?)&.full_address || @saved_addresses.first.full_address,
                    data: { address_selector_target: "field" } %>

              <%# Saved address cards %>
              <div class="space-y-3 mb-4">
                <% @saved_addresses.each_with_index do |address, i| %>
                  <div class="border-2 rounded-2xl px-5 py-4 cursor-pointer transition-all hover:border-indigo-400
                              <%= i == 0 ? 'border-indigo-600 bg-indigo-50/30' : 'border-gray-200' %>"
                       data-address-selector-target="card"
                       data-address="<%= address.full_address %>"
                       data-action="click->address-selector#select">
                    <p class="text-sm font-bold text-gray-900"><%= address.full_name %> &middot; <span class="font-medium text-gray-500"><%= address.phone %></span></p>
                    <p class="text-sm text-gray-500 mt-0.5"><%= address.full_address %></p>
                    <% if address.is_default? %>
                      <span class="inline-block mt-2 px-2 py-0.5 bg-indigo-50 text-indigo-600 text-[10px] font-bold uppercase tracking-wider rounded-full border border-indigo-100">Default</span>
                    <% end %>
                  </div>
                <% end %>
              </div>

              <%# Enter manually toggle %>
              <button type="button" class="text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors"
                      data-action="click->address-selector#enterManually">
                + Enter a different address
              </button>

              <%# Manual textarea (hidden by default) %>
              <div class="hidden mt-4" data-address-selector-target="manual">
                <textarea rows="4"
                          placeholder="House number, street name, city, province..."
                          class="w-full rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition resize-none border border-gray-200"
                          data-address-selector-target="textarea"
                          data-action="input->address-selector#syncField"></textarea>
              </div>

              <% if @order.errors[:shipping_address].any? %>
                <p class="text-xs text-red-500 mt-2 font-medium"><%= @order.errors[:shipping_address].first %></p>
              <% end %>
            </div>
          <% else %>
            <div>
              <%= f.label :shipping_address, class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
              <%= f.text_area :shipping_address, rows: 4, placeholder: "House number, street name, city, province...", required: true,
                  class: "w-full rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none transition resize-none #{@order.errors[:shipping_address].any? ? 'border-2 border-red-400 bg-red-50' : 'border border-gray-200'}" %>
              <% if @order.errors[:shipping_address].any? %>
                <p class="text-xs text-red-500 mt-1 font-medium"><%= @order.errors[:shipping_address].first %></p>
              <% end %>
            </div>
          <% end %>
        </div>

        <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
          <h2 class="text-sm font-black text-gray-900 uppercase tracking-widest mb-8 flex items-center gap-3">
            <span class="w-6 h-6 bg-gray-900 text-white rounded-full flex items-center justify-center text-[10px]">3</span>
            Payment Method
          </h2>
          
          <div class="p-4 border-2 border-indigo-600 bg-indigo-50/30 rounded-2xl flex items-center gap-4">
            <div class="w-5 h-5 border-4 border-indigo-600 rounded-full flex items-center justify-center">
              <div class="w-2 h-2 bg-indigo-600 rounded-full"></div>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900">Bank Transfer / Manual Verification</p>
              <p class="text-[10px] text-gray-500 font-medium">Pay manually and upload proof of payment later.</p>
            </div>
          </div>
        </div>
      </div>

      <%# Right: Summary %>
      <div class="space-y-6">
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm sticky top-24 overflow-hidden">

          <%# Order items %>
          <div class="p-6 space-y-4">
            <% current_cart&.cart_items&.includes(product_variant: :product)&.each do |item| %>
              <div class="flex items-start justify-between gap-3 text-sm">
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-gray-900 truncate"><%= item.product_variant.product.name %></p>
                  <p class="text-xs text-gray-400 mt-0.5"><%= item.product_variant.option_text %> &times; <%= item.quantity %></p>
                </div>
                <span class="font-bold text-gray-900 shrink-0">Rp <%= number_with_delimiter(item.product_variant.price.to_i * item.quantity) %></span>
              </div>
            <% end %>
          </div>

          <%# Coupon input %>
          <div class="px-6 pb-5">
            <div class="flex gap-2">
              <input type="text" placeholder="Discount code"
                     class="flex-1 min-w-0 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono uppercase tracking-wider placeholder:normal-case placeholder:tracking-normal placeholder:font-sans"
                     data-coupon-target="input">
              <button type="button"
                      class="shrink-0 border border-gray-900 text-gray-900 px-4 py-2.5 rounded-xl text-sm font-bold hover:bg-gray-900 hover:text-white transition-all"
                      data-action="click->coupon#apply">
                Apply
              </button>
            </div>
            <p class="mt-2 text-xs font-medium" data-coupon-target="message"></p>
          </div>

          <%# Totals %>
          <div class="border-t border-gray-100 px-6 py-5 space-y-3 text-sm">
            <div class="flex justify-between text-gray-500">
              <span>Subtotal</span>
              <span class="text-gray-900 font-medium">Rp <%= number_with_delimiter(@total_price) %></span>
            </div>
            <div style="display:none" class="justify-between text-emerald-600 font-semibold" data-coupon-target="discountRow">
              <span>Discount</span>
              <span data-coupon-target="discountAmount"></span>
            </div>
            <div class="flex justify-between text-gray-500">
              <span>Shipping</span>
              <span class="text-emerald-600 font-semibold">Free</span>
            </div>
          </div>

          <%# Total row %>
          <div class="bg-gray-50 px-6 py-4 flex justify-between items-center">
            <span class="text-sm font-bold text-gray-900">Total</span>
            <span class="text-xl font-black text-gray-900" data-coupon-target="total">Rp <%= number_with_delimiter(@total_price) %></span>
          </div>

          <%# CTA %>
          <div class="px-6 py-5">
            <%= f.submit "Complete Purchase",
                class: "w-full bg-gray-900 text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transition-all shadow-lg active:scale-95 cursor-pointer" %>
            <p class="text-[11px] text-gray-400 text-center mt-3 leading-relaxed">
              By completing this purchase you agree to our Terms &amp; Privacy Policy.
            </p>
          </div>

        </div>
      </div>
    <% end %>

  </div>
</div>
