<% content_for :title, "Unprocessable Request" %>

<div class="min-h-screen bg-gray-50/50 flex items-center justify-center px-6">
  <div class="text-center max-w-md">
    <p class="text-8xl font-black text-gray-900 tracking-tight">422</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900">Invalid request</h1>
    <p class="mt-3 text-gray-500 text-sm leading-relaxed">
      The request couldn't be processed. This may be due to an expired form or invalid data.
    </p>
    <div class="mt-8 flex items-center justify-center gap-4">
      <%= link_to "Go Home", root_path, class: "bg-gray-900 text-white px-6 py-3 rounded-xl text-sm font-bold hover:bg-gray-800 transition-all" %>
      <%= link_to "Browse Products", products_path, class: "text-sm font-semibold text-gray-600 hover:text-gray-900 transition-colors" %>
    </div>
  </div>
</div>
