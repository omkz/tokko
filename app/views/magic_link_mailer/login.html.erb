<div style="font-family: sans-serif; max-width: 480px; margin: 0 auto; padding: 32px;">
  <h1 style="font-size: 24px; font-weight: 800; color: #111827; margin-bottom: 8px;">Your login link</h1>
  <p style="color: #6b7280; margin-bottom: 32px;">Click the button below to sign in to Tokko. This link expires in 15 minutes.</p>

  <a href="<%= @url %>" style="display: inline-block; background: #111827; color: #ffffff; padding: 14px 28px; border-radius: 12px; font-weight: 700; text-decoration: none; font-size: 15px;">
    Sign in to Tokko
  </a>

  <p style="margin-top: 32px; color: #9ca3af; font-size: 12px;">
    If you didn't request this, you can ignore this email.<br>
    Link: <%= @url %>
  </p>
</div>
