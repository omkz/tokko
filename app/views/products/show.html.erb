<div class="min-h-screen bg-gray-50">

  <%# Header %>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to products_path, class: "text-gray-400 hover:text-gray-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        <% end %>
        <span class="text-gray-300">/</span>
        <h1 class="text-lg font-semibold text-gray-900"><%= @product.name %></h1>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
          <%= @product.status == 'active' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
          <%= @product.status&.capitalize || 'Draft' %>
        </span>
      </div>
      <%= link_to "Edit", edit_product_path(@product),
        class: "bg-gray-900 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors" %>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-8 grid grid-cols-3 gap-8">
    <div class="col-span-2 space-y-6">

      <%# Product Info %>
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="font-semibold text-gray-900 mb-1"><%= @product.name %></h2>
        <p class="text-gray-500 text-sm"><%= @product.description.presence || "No description" %></p>
      </div>

      <%# Options %>
      <% if @product.product_options.any? %>
        <div class="bg-white rounded-2xl border border-gray-200 p-6">
          <h2 class="font-semibold text-gray-900 mb-4">Options</h2>
          <div class="space-y-3">
            <% @product.product_options.each do |option| %>
              <div>
                <div class="text-xs text-gray-500 mb-1.5"><%= option.name %></div>
                <div class="flex flex-wrap gap-2">
                  <% option.product_option_values.each do |val| %>
                    <span class="bg-gray-100 text-gray-700 text-sm px-3 py-1 rounded-full"><%= val.value %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Variants %>
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="font-semibold text-gray-900 mb-5">
          Variants
          <span class="text-gray-400 font-normal text-sm ml-1">(<%= @variants.count %>)</span>
        </h2>
        <% if @variants.any? %>
          <div class="border border-gray-200 rounded-xl overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3">Variant</th>
                  <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3">SKU</th>
                  <th class="text-right text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3">Price</th>
                  <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3">Stock</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% @variants.each do |variant| %>
                  <tr class="<%= variant.active? ? '' : 'opacity-50' %>">
                    <td class="px-4 py-3 font-medium text-gray-900"><%= variant.option_text %></td>
                    <td class="px-4 py-3 text-gray-500 font-mono text-xs"><%= variant.sku %></td>
                    <td class="px-4 py-3 text-right font-medium">Rp <%= number_with_delimiter(variant.price.to_i) %></td>
                    <td class="px-4 py-3 text-center">
                      <span class="<%= variant.stock.to_i > 0 ? 'text-green-700 bg-green-50' : 'text-gray-400 bg-gray-50' %> text-xs font-medium px-2 py-0.5 rounded-full">
                        <%= variant.stock %>
                      </span>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-gray-400 text-sm text-center py-8">No variants yet</p>
        <% end %>
      </div>

    </div>

    <%# Sidebar %>
    <div class="space-y-5">
      <div class="bg-white rounded-2xl border border-gray-200 p-5">
        <h3 class="font-semibold text-gray-900 mb-4 text-sm">Summary</h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Total variants</span>
            <span class="font-medium"><%= @product.product_variants.count %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Total stock</span>
            <span class="font-medium"><%= @product.product_variants.sum(:stock) %></span>
          </div>
          <% prices = @product.product_variants.pluck(:price).compact %>
          <% if prices.any? %>
            <div class="flex justify-between border-t border-gray-100 pt-3">
              <span class="text-gray-500">Price range</span>
              <span class="font-medium">
                Rp <%= number_with_delimiter(prices.min.to_i) %>
                <% if prices.min != prices.max %> – Rp <%= number_with_delimiter(prices.max.to_i) %><% end %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

</div>
