<div class="bg-white min-h-screen pb-24" 
     data-controller="product-selection" 
     data-product-selection-variants-value="<%= @product.product_variants.map { |v| { id: v.id, price: v.price.to_i, active: v.active?, stock: v.stock, options: v.product_option_values.joins(:product_option).pluck('product_options.name', 'product_option_values.value').to_h } }.to_json %>">
  
  <div class="max-w-7xl mx-auto px-6 py-12">
    <%# Breadcrumbs %>
    <nav class="flex mb-8 text-sm font-medium text-gray-400">
      <%= link_to "Home", root_path, class: "hover:text-gray-900 transition-colors" %>
      <span class="mx-2">/</span>
      <span class="text-gray-900"><%= @product.name %></span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-16 gap-y-10">
      <%# Left: Gallery %>
      <div class="space-y-4">
        <div class="aspect-square rounded-3xl overflow-hidden bg-gray-50 border border-gray-100 shadow-sm">
          <% if @product.images.attached? %>
            <%= image_tag @product.images.first, class: "w-full h-full object-cover object-center" %>
          <% else %>
            <div class="w-full h-full flex items-center justify-center text-8xl opacity-10">📦</div>
          <% end %>
        </div>
      </div>

      <%# Right: Info & Actions %>
      <div class="flex flex-col">
        <div class="mb-8">
          <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-2"><%= @product.name %></h1>
          <div class="flex items-center gap-4">
            <p class="text-2xl font-bold text-gray-900" data-product-selection-target="price">
              Rp <%= number_with_delimiter(@product.product_variants.first&.price.to_i) %>
            </p>
            <span class="px-2 py-1 bg-green-50 text-green-700 text-[10px] font-bold uppercase tracking-wider rounded-md border border-green-100">In Stock</span>
          </div>
        </div>

        <div class="prose prose-sm text-gray-500 mb-10 max-w-none leading-relaxed">
          <%= simple_format @product.description %>
        </div>

        <%# Options Builder %>
        <div class="border-t border-gray-100 pt-8 space-y-8">
          <% @product.product_options.each do |option| %>
            <div>
              <h3 class="text-sm font-bold text-gray-900 uppercase tracking-widest mb-4"><%= option.name %></h3>
              <div class="flex flex-wrap gap-3">
                <% option.product_option_values.each_with_index do |v, idx| %>
                  <button type="button"
                    data-action="click->product-selection#selectOption"
                    data-option="<%= option.name %>"
                    data-value="<%= v.value %>"
                    class="px-6 py-3 border rounded-xl text-sm font-bold transition-all active:scale-95 <%= idx == 0 ? 'border-indigo-600 text-indigo-600 ring-2 ring-indigo-100' : 'border-gray-200 text-gray-600 hover:border-indigo-600' %>">
                    <%= v.value %>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Add to Cart Form %>
          <%= form_with url: add_to_cart_path, method: :post, class: "pt-4 flex gap-4" do |f| %>
            <%= hidden_field_tag :variant_id, @product.product_variants.first&.id, data: { product_selection_target: "variantId" } %>
            <%= f.hidden_field :quantity, value: 1 %>
            
            <button type="submit" 
                    data-product-selection-target="button"
                    class="flex-1 bg-gray-900 text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transition-all shadow-xl active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
              Add to Cart
            </button>
            
            <button type="button" class="p-4 border border-gray-200 rounded-2xl hover:bg-gray-50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </button>
          <% end %>
        </div>

        <%# Features %>
        <div class="mt-12 grid grid-cols-2 gap-4">
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center shadow-sm">🚚</div>
            <span class="text-xs font-semibold text-gray-600">Free Shipping</span>
          </div>
          <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center shadow-sm">🛡️</div>
            <span class="text-xs font-semibold text-gray-600">Secure Payment</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Related Products %>
  <% if @related_products.any? %>
    <div class="max-w-7xl mx-auto px-6 py-24 border-t border-gray-100">
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-gray-900 tracking-tight">You Might Also Like</h2>
        <p class="text-sm text-gray-500 mt-1">Customers who viewed this item also loved these.</p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
        <% @related_products.each do |product| %>
          <div class="group relative flex flex-col">
            <div class="aspect-square w-full overflow-hidden rounded-3xl bg-gray-100 group-hover:opacity-75 transition-all duration-300 shadow-sm border border-gray-50">
              <% if product.images.attached? %>
                <%= image_tag product.images.first, class: "h-full w-full object-cover object-center" %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center text-5xl opacity-20">📦</div>
              <% end %>
            </div>
            
            <div class="mt-4 flex flex-col flex-1">
              <h3 class="text-sm font-bold text-gray-700">
                <%= link_to product_path(product) do %>
                  <span aria-hidden="true" class="absolute inset-0"></span>
                  <%= product.name %>
                <% end %>
              </h3>
              <div class="mt-1 flex items-center justify-between">
                <% prices = product.product_variants.pluck(:price).compact %>
                <p class="text-sm font-black text-gray-900">
                  <% if prices.any? %>
                    Rp <%= number_with_delimiter(prices.min.to_i) %>
                  <% else %>
                    —
                  <% end %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
