<div class="min-h-screen bg-gray-50">

  <%# Sticky header %>
  <div class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to products_path, class: "text-gray-400 hover:text-gray-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        <% end %>
        <h1 class="text-lg font-semibold text-gray-900">Edit Product</h1>
      </div>
      <button form="product-info-form" type="submit"
        class="bg-gray-900 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-gray-700 transition-colors">
        Save
      </button>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-8 grid grid-cols-3 gap-8">

    <%# ══ Left column ══ %>
    <div class="col-span-2 space-y-6">

      <%# Flash %>
      <% flash.each do |type, msg| %>
        <div class="rounded-xl px-5 py-4 text-sm font-medium
          <%= type == 'notice' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' %>">
          <%= msg %>
        </div>
      <% end %>

      <%# ── Product Info ── %>
      <%= form_with model: @product, id: "product-info-form",
        class: "bg-white rounded-2xl border border-gray-200 p-6 space-y-5" do |f| %>
        <h2 class="font-semibold text-gray-900">Product Information</h2>

        <div>
          <%= f.label :name, "Title", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_field :name,
            class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition",
            placeholder: "e.g. Classic T-Shirt" %>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <%= f.text_area :description, rows: 4,
            class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition resize-none",
            placeholder: "Describe your product..." %>
        </div>

        <div>
          <%= f.label :slug, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
          <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-gray-900">
            <span class="bg-gray-50 text-gray-400 text-sm px-3 py-2.5 border-r border-gray-300 select-none">/products/</span>
            <%= f.text_field :slug, class: "flex-1 px-3 py-2.5 text-sm outline-none",
              placeholder: "classic-t-shirt" %>
          </div>
        </div>
      <% end %>

      <%# ── Options Builder ── %>
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-5">
          <div>
            <h2 class="font-semibold text-gray-900">Options</h2>
            <p class="text-xs text-gray-400 mt-0.5">Up to 3 options, e.g. Size, Color</p>
          </div>
        </div>

        <%# Existing options %>
        <div class="space-y-3 mb-5">
          <% @product.product_options.each do |option| %>
            <div class="border border-gray-200 rounded-xl p-4">
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></span>
                  <span class="font-medium text-sm text-gray-900"><%= option.name %></span>
                  <span class="text-xs text-gray-400">(<%= option.product_option_values.count %> values)</span>
                </div>
                <%= button_to product_option_path(option),
                  method: :delete,
                  data: { turbo_confirm: "Remove '#{option.name}'?" },
                  class: "text-xs text-gray-400 hover:text-red-500 transition-colors" do %>
                  Remove
                <% end %>
              </div>
              <div class="flex flex-wrap gap-1.5">
                <% option.product_option_values.each do |v| %>
                  <span class="bg-gray-100 text-gray-700 text-xs px-3 py-1 rounded-full"><%= v.value %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <%# Add option form %>
        <% if @product.product_options.count < 3 %>
          <%= form_with url: product_product_options_path(@product), method: :post,
            data: { controller: "option-form" },
            class: "border-2 border-dashed border-gray-200 rounded-xl p-5 space-y-4" do |f| %>

            <h3 class="text-sm font-semibold text-gray-700">+ Add Option</h3>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1.5">Option Name</label>
                <input type="text" name="product_option[name]"
                  placeholder="e.g. Size"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition" />
              </div>
              <div>
                <label class="block text-xs font-medium text-gray-500 mb-1.5">Values <span class="text-gray-400">(comma separated)</span></label>
                <input type="text" name="option_values_raw"
                  placeholder="S, M, L, XL"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-gray-900 focus:border-transparent transition"
                  data-action="input->option-form#parseValues" />
              </div>
            </div>

            <%# Hidden nested fields injected by JS %>
            <div data-option-form-target="hiddenValues"></div>

            <%# Live preview %>
            <div class="flex flex-wrap gap-1.5 min-h-[28px]" data-option-form-target="preview"></div>

            <div class="flex justify-end">
              <button type="submit"
                class="bg-gray-900 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-gray-700 transition-colors cursor-pointer">
                Add Option
              </button>
            </div>
          <% end %>
        <% else %>
          <div class="border-2 border-dashed border-gray-100 rounded-xl p-4 text-center text-sm text-gray-400">
            Maximum 3 options reached
          </div>
        <% end %>
      </div>

      <%# ── Variants Table ── %>
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <div class="flex items-center justify-between mb-5">
          <div>
            <h2 class="font-semibold text-gray-900">Variants</h2>
            <p class="text-xs text-gray-400 mt-0.5"><%= @product.product_variants.count %> variant(s)</p>
          </div>
          <% if @product.product_options.any? %>
            <%= button_to generate_variants_product_path(@product), method: :post,
              class: "flex items-center gap-2 bg-indigo-600 text-white text-sm font-medium px-4 py-2 rounded-lg hover:bg-indigo-700 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Generate Variants
            <% end %>
          <% end %>
        </div>

        <% if @product.product_variants.any? %>
          <div class="border border-gray-200 rounded-xl overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3">Variant</th>
                  <th class="text-left text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3 w-36">SKU</th>
                  <th class="text-right text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3 w-32">Price (Rp)</th>
                  <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3 w-24">Stock</th>
                  <th class="text-center text-xs font-medium text-gray-500 uppercase tracking-wide px-4 py-3 w-16">Active</th>
                  <th class="w-16 px-4 py-3"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% @product.product_variants.each do |variant| %>
                  <%# One form per variant row for inline edit %>
                  <%= form_with model: variant, url: product_variant_path(variant), method: :patch,
                    id: "variant-form-#{variant.id}",
                    class: "contents" do |f| %>
                    <tr class="hover:bg-gray-50/70 group transition-colors <%= 'opacity-50' unless variant.active? %>">
                      <td class="px-4 py-3 font-medium text-gray-900">
                        <%= variant.option_text %>
                      </td>
                      <td class="px-4 py-3">
                        <%= f.text_field :sku,
                          class: "border border-gray-200 rounded-lg px-2.5 py-1.5 w-full text-xs text-gray-600 font-mono focus:border-gray-400 focus:ring-0 outline-none transition hover:border-gray-300 bg-transparent" %>
                      </td>
                      <td class="px-4 py-3">
                        <%= f.number_field :price, step: "1", min: 0,
                          class: "border border-gray-200 rounded-lg px-2.5 py-1.5 w-full text-right text-sm focus:border-gray-400 outline-none transition hover:border-gray-300 bg-transparent",
                          data: { action: "change->variant-row#autoSubmit" } %>
                      </td>
                      <td class="px-4 py-3">
                        <%= f.number_field :stock, min: 0,
                          class: "border border-gray-200 rounded-lg px-2.5 py-1.5 w-full text-center text-sm focus:border-gray-400 outline-none transition hover:border-gray-300 bg-transparent",
                          data: { action: "change->variant-row#autoSubmit" } %>
                      </td>
                      <td class="px-4 py-3 text-center">
                        <%= f.check_box :active,
                          class: "w-4 h-4 rounded text-indigo-600 border-gray-300 cursor-pointer",
                          data: { action: "change->variant-row#autoSubmit" } %>
                      </td>
                      <td class="px-4 py-3 text-right">
                        <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                          <button type="submit" form="variant-form-<%= variant.id %>"
                            class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition-colors">
                            Save
                          </button>
                          <%= button_to product_variant_path(variant), method: :delete,
                            data: { turbo_confirm: "Delete this variant?" },
                            class: "text-xs text-gray-400 hover:text-red-500 transition-colors" do %>
                            Del
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                <% end %>
              </tbody>
            </table>
          </div>

        <% else %>
          <div class="border-2 border-dashed border-gray-200 rounded-xl p-10 text-center">
            <div class="text-4xl mb-3">📦</div>
            <p class="text-gray-500 text-sm font-medium">No variants yet</p>
            <% if @product.product_options.any? %>
              <p class="text-xs text-gray-400 mt-1">Click "Generate Variants" above to create all combinations.</p>
            <% else %>
              <p class="text-xs text-gray-400 mt-1">Add options first, then generate variants.</p>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>

    <%# ══ Sidebar ══ %>
    <div class="space-y-5">

      <%# Status %>
      <%= form_with model: @product, class: "bg-white rounded-2xl border border-gray-200 p-5 space-y-4" do |f| %>
        <h3 class="font-semibold text-gray-900 text-sm">Status</h3>
        <%= f.select :status,
          [["🟢 Active", "active"], ["📝 Draft", "draft"], ["📦 Archived", "archived"]],
          {},
          class: "w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm focus:ring-2 focus:ring-gray-900 outline-none" %>
        <%= f.submit "Update Status",
          class: "w-full bg-gray-100 hover:bg-gray-200 text-gray-800 text-sm font-medium px-4 py-2.5 rounded-lg cursor-pointer transition-colors" %>
      <% end %>

      <%# Summary %>
      <div class="bg-white rounded-2xl border border-gray-200 p-5">
        <h3 class="font-semibold text-gray-900 text-sm mb-4">Summary</h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-500">Options</span>
            <span class="font-semibold"><%= @product.product_options.count %> / 3</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Variants</span>
            <span class="font-semibold"><%= @product.product_variants.count %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-500">Total stock</span>
            <span class="font-semibold"><%= @product.product_variants.sum(:stock) %></span>
          </div>
          <% prices = @product.product_variants.pluck(:price).compact %>
          <% if prices.any? %>
            <div class="border-t border-gray-100 pt-3 flex justify-between">
              <span class="text-gray-500">Price range</span>
              <span class="font-semibold text-right">
                <% if prices.min == prices.max %>
                  Rp <%= number_with_delimiter(prices.min.to_i) %>
                <% else %>
                  Rp <%= number_with_delimiter(prices.min.to_i) %><br>– Rp <%= number_with_delimiter(prices.max.to_i) %>
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <%# View product %>
      <div class="bg-white rounded-2xl border border-gray-200 p-5">
        <%= link_to product_path(@product),
          class: "flex items-center justify-center gap-2 text-sm text-gray-700 hover:text-gray-900 font-medium transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          View Product
        <% end %>
      </div>

      <%# Danger zone %>
      <div class="bg-white rounded-2xl border border-red-100 p-5">
        <h3 class="text-sm font-semibold text-red-600 mb-3">Danger Zone</h3>
        <%= button_to product_path(@product), method: :delete,
          data: { turbo_confirm: "Permanently delete '#{@product.name}'? This cannot be undone." },
          class: "w-full text-center border border-red-200 text-red-500 hover:bg-red-50 text-sm font-medium px-4 py-2.5 rounded-lg transition-colors" do %>
          Delete Product
        <% end %>
      </div>

    </div>
  </div>

</div>
