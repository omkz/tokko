<% content_for :title, params[:q].present? ? "Search: #{params[:q]}" : "All Products" %>
<%= render "shared/catalog",
           title: params[:q].present? ? "Search Results" : "All Products",
           description: params[:q].present? ? "Showing results for '#{params[:q]}'" : "Explore our full range of curated essentials.",
           breadcrumbs: [
             { name: params[:q].present? ? "Search: #{params[:q]}" : "All Products" }
           ] %>
