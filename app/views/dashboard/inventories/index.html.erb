<div class="pb-12">
  
  <%# Header Section %>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Inventory Quick-Editor</h1>
          <p class="text-sm text-gray-500 mt-1">Bulk update stock levels for all product variants.</p>
        </div>
        
        <div class="flex items-center gap-3">
          <%# Search Form %>
          <%= form_with url: dashboard_inventory_path, method: :get, class: "relative group" do |f| %>
            <%= f.text_field :q, value: params[:q], placeholder: "Search product name...", 
                class: "bg-gray-50 border border-gray-100 rounded-xl pl-10 pr-10 py-2.5 text-sm w-64 focus:w-80 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-all outline-none" %>
            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-8">
    <%= form_with url: dashboard_inventory_update_all_path(q: params[:q], page: params[:page]), method: :patch do |f| %>
      <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm">
        <table class="w-full">
          <thead class="bg-gray-50/50 border-b border-gray-100">
            <tr>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Product / Variant</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">SKU</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4 w-40">Current Stock</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4 w-40">New Stock</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @variants.each do |variant| %>
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-lg bg-gray-50 border border-gray-100 flex items-center justify-center shrink-0 overflow-hidden">
                      <% if variant.product.images.attached? %>
                        <%= image_tag variant.product.images.first.variant(resize_to_limit: [100, 100]), class: "w-full h-full object-cover" %>
                      <% else %>
                        <span>📦</span>
                      <% end %>
                    </div>
                    <div>
                      <span class="block text-sm font-bold text-gray-900"><%= variant.product.name %></span>
                      <span class="block text-xs text-gray-400 mt-0.5"><%= variant.option_text %></span>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <code class="text-[10px] bg-gray-100 px-2 py-1 rounded-md text-gray-600 font-bold"><%= variant.sku %></code>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold 
                    <%= variant.stock <= 5 ? 'bg-red-50 text-red-600' : 'bg-gray-50 text-gray-600' %>">
                    <%= variant.stock %> in stock
                  </span>
                </td>
                <td class="px-6 py-4">
                  <%= number_field_tag "variants[#{variant.id}][stock]", variant.stock.to_i, class: "w-24 px-3 py-2 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none font-bold" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        
        <div class="px-6 py-6 bg-gray-50/50 border-t border-gray-100 flex items-center justify-between">
          <div class="text-sm text-gray-500">
            Showing <span class="font-bold text-gray-900"><%= @variants.size %></span> variants on this page.
          </div>
          <button type="submit" class="bg-indigo-600 text-white px-8 py-3 rounded-2xl font-bold text-sm hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100 active:scale-95">
            Save All Changes
          </button>
        </div>
      </div>
    <% end %>

    <div class="mt-12 flex justify-center pb-12">
      <div class="pagy">
        <%== @pagy.series_nav %>
      </div>
    </div>
  </div>
</div>
