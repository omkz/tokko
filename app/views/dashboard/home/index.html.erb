<div class="p-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Store Overview</h1>
    <p class="text-sm text-gray-500 mt-1">Here's what's happening with your store today.</p>
  </div>

  <%# Stats Grid %>
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Total Revenue</p>
      <p class="text-2xl font-black text-gray-900">Rp <%= number_with_delimiter(@total_revenue.to_i) %></p>
      <p class="mt-2 text-[10px] font-bold text-gray-400">Paid + shipped + completed orders</p>
    </div>

    <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Total Orders</p>
      <p class="text-2xl font-black text-gray-900"><%= @orders_count %></p>
      <p class="mt-2 text-[10px] font-bold text-gray-400">All time</p>
    </div>

    <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Total Products</p>
      <p class="text-2xl font-black text-gray-900"><%= @products_count %></p>
      <p class="mt-2 text-[10px] font-bold text-gray-400">In catalog</p>
    </div>

    <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
      <p class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Low Stock</p>
      <p class="text-2xl font-black <%= @low_stock_count > 0 ? 'text-red-600' : 'text-gray-900' %>"><%= @low_stock_count %></p>
      <p class="mt-2 text-[10px] font-bold text-gray-400">Variants with ≤ 5 units</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <%# Sales Chart %>
    <div class="lg:col-span-2 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-bold text-gray-900 uppercase tracking-widest text-xs">Sales Performance</h2>
        <div class="flex gap-2">
          <span class="px-3 py-1 bg-gray-50 border border-gray-100 rounded-lg text-[10px] font-bold text-gray-400">Last 7 Days</span>
        </div>
      </div>
      <div class="h-64">
        <canvas data-controller="dashboard-chart" 
                data-dashboard-chart-data-value="<%= @sales_data.to_json %>"></canvas>
      </div>
    </div>

    <%# Recent Orders %>
    <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
      <h2 class="font-bold text-gray-900 uppercase tracking-widest text-xs mb-6">Recent Orders</h2>
      <div class="space-y-6">
        <% @recent_orders.each do |order| %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gray-50 flex items-center justify-center text-xs font-bold text-gray-400">
                <%= order.customer_name[0] %>
              </div>
              <div>
                <p class="text-sm font-bold text-gray-900"><%= order.customer_name %></p>
                <p class="text-[10px] text-gray-400 font-medium"><%= time_ago_in_words(order.created_at) %> ago</p>
              </div>
            </div>
            <p class="text-sm font-black text-gray-900">Rp <%= number_with_delimiter(order.total_price.to_i) %></p>
          </div>
        <% end %>
      </div>
      <%= link_to dashboard_orders_path, class: "block text-center mt-8 text-xs font-bold text-indigo-600 hover:text-indigo-800 transition-colors" do %>
        View All Orders →
      <% end %>
    </div>
  </div>

  <%# Secondary Grid %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
    <%# Top Products %>
    <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
      <h2 class="font-bold text-gray-900 uppercase tracking-widest text-xs mb-6">Top Products</h2>
      <% if @top_products.any? %>
        <div class="space-y-4">
          <% @top_products.each do |product| %>
            <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-2xl transition-colors">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 overflow-hidden flex items-center justify-center">
                  <% if product.images.attached? %>
                    <%= image_tag product.images.first.variant(resize_to_limit: [100, 100]), class: "w-full h-full object-cover" %>
                  <% else %>
                    <span class="text-lg">📦</span>
                  <% end %>
                </div>
                <p class="text-sm font-bold text-gray-900"><%= product.name %></p>
              </div>
              <div class="text-right">
                <p class="text-sm font-black text-gray-900"><%= product.total_sold %> sold</p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 text-center py-8">No sales data yet.</p>
      <% end %>
    </div>

    <%# System Status %>
    <div class="bg-indigo-600 rounded-3xl p-8 text-white relative overflow-hidden shadow-xl shadow-indigo-100">
      <div class="relative z-10">
        <h2 class="font-bold uppercase tracking-widest text-[10px] opacity-80 mb-6">System Status</h2>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium opacity-90">Image Processing (Vips)</span>
            <span class="px-2 py-0.5 bg-white/20 rounded-md text-[10px] font-bold">ACTIVE</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium opacity-90">Database (Postgres)</span>
            <span class="px-2 py-0.5 bg-white/20 rounded-md text-[10px] font-bold">HEALTHY</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium opacity-90">Turbo Streams</span>
            <span class="px-2 py-0.5 bg-white/20 rounded-md text-[10px] font-bold">CONNECTED</span>
          </div>
        </div>
        <div class="mt-10 pt-6 border-t border-white/10">
          <p class="text-xs font-medium opacity-80">"Your store is running smoothly. All systems are operational."</p>
        </div>
      </div>
      <%# Abstract background shape %>
      <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
    </div>
  </div>
</div>
