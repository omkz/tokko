<div class="pb-12">
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Filters</h1>
        <p class="text-sm text-gray-500 mt-1">Manage storefront faceted filters.</p>
      </div>
      <%= link_to new_dashboard_filter_group_path, class: "bg-gray-900 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-gray-800 transition-all shadow-lg shadow-gray-200 flex items-center gap-2" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4" /></svg>
        New Filter Group
      <% end %>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-8 space-y-4">
    <% if @filter_groups.any? %>
      <% @filter_groups.each do |group| %>
        <div class="bg-white border border-gray-200 rounded-3xl p-6 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-3">
                <h2 class="text-sm font-bold text-gray-900"><%= group.name %></h2>
                <span class="text-[10px] font-bold text-gray-400 bg-gray-50 px-2 py-0.5 rounded-md border border-gray-100">/<%= group.slug %></span>
              </div>
              <div class="flex flex-wrap gap-2">
                <% if group.filter_options.any? %>
                  <% group.filter_options.ordered.each do |opt| %>
                    <span class="inline-flex items-center px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs font-bold rounded-lg border border-indigo-100">
                      <%= opt.value %>
                    </span>
                  <% end %>
                <% else %>
                  <span class="text-xs text-gray-400 italic">No options yet</span>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <%= link_to edit_dashboard_filter_group_path(group), class: "p-2 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-all" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
              <% end %>
              <%= button_to dashboard_filter_group_path(group), method: :delete, data: { turbo_confirm: "Delete \"#{group.name}\" and all its options?" }, class: "p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all cursor-pointer" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white border-2 border-dashed border-gray-200 rounded-3xl py-24 text-center">
        <div class="w-16 h-16 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-3xl opacity-40">🔽</div>
        <p class="text-sm font-bold text-gray-900">No filter groups yet</p>
        <p class="text-xs text-gray-500 mt-1 mb-6">Create groups like "Size", "Color", or "Material" to power storefront filters.</p>
        <%= link_to "Create First Filter Group", new_dashboard_filter_group_path, class: "inline-block bg-gray-900 text-white px-6 py-2.5 rounded-xl text-sm font-bold hover:bg-gray-800 transition-all" %>
      </div>
    <% end %>
  </div>
</div>
