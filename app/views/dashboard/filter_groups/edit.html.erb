<div class="pb-12">
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-2xl mx-auto px-6 py-8 flex items-center gap-4">
      <%= link_to dashboard_filter_groups_path, class: "text-gray-400 hover:text-gray-700 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Edit: <%= @filter_group.name %></h1>
        <p class="text-sm text-gray-500 mt-1"><%= @filter_group.filter_options.count %> options</p>
      </div>
    </div>
  </div>

  <div class="max-w-2xl mx-auto px-6 mt-8 space-y-6">

    <%# Group Settings %>
    <div class="bg-white border border-gray-200 rounded-3xl p-8 shadow-sm">
      <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest mb-6">Group Settings</h2>
      <%= render "form", filter_group: @filter_group %>
    </div>

    <%# Filter Options %>
    <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm">
      <div class="px-8 py-5 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
        <h2 class="text-xs font-bold text-gray-900 uppercase tracking-widest">Options</h2>
        <span class="text-xs font-bold text-gray-400"><%= @filter_group.filter_options.count %> total</span>
      </div>

      <% if @filter_group.filter_options.any? %>
        <div class="divide-y divide-gray-100">
          <% @filter_group.filter_options.ordered.each do |option| %>
            <div class="px-8 py-4 flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= option.value %></p>
                <p class="text-[10px] text-gray-400 font-medium mt-0.5"><%= option.slug %></p>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xs text-gray-400"><%= option.product_filter_options.size %> products</span>
                <%= button_to dashboard_filter_option_path(option), method: :delete,
                    data: { turbo_confirm: "Remove \"#{option.value}\"?" },
                    class: "p-1.5 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all cursor-pointer" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-8 py-8 text-center">
          <p class="text-sm text-gray-400">No options yet. Add one below.</p>
        </div>
      <% end %>

      <%# Add Option Form %>
      <div class="px-8 py-6 border-t border-gray-100 bg-gray-50/30">
        <%= form_with url: dashboard_filter_group_filter_options_path(@filter_group), method: :post, class: "flex gap-3" do |f| %>
          <%= f.text_field :value, placeholder: "e.g. Small, Red, Cotton…",
              name: "filter_option[value]",
              class: "flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all" %>
          <%= f.submit "Add Option", class: "bg-indigo-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-indigo-700 transition-all cursor-pointer" %>
        <% end %>
      </div>
    </div>

  </div>
</div>
