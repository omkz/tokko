<div class="pb-12">

  <%# Header %>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-8 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Movement History</h1>
        <p class="text-sm text-gray-500 mt-1">Full audit log of all inventory changes.</p>
      </div>
      <%= link_to dashboard_inventory_path, class: "flex items-center gap-2 text-sm font-bold text-gray-600 bg-gray-100 hover:bg-gray-200 px-4 py-2.5 rounded-xl transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
        Edit Stock Levels
      <% end %>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-8">

    <%# Filters %>
    <%= form_with url: dashboard_inventory_movements_path, method: :get, class: "flex items-center gap-3 mb-6" do |f| %>
      <div class="relative group flex-1 max-w-xs">
        <%= f.text_field :q, value: params[:q], placeholder: "Search product...",
            class: "w-full bg-gray-50 border border-gray-100 rounded-xl pl-9 pr-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" %>
        <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        </div>
      </div>

      <%= f.select :reason,
          options_for_select([
            ["All Reasons", ""],
            ["Restock", "restock"],
            ["Sale", "sale"],
            ["Return", "return"],
            ["Adjustment", "adjustment"],
            ["Damage", "damage"]
          ], params[:reason]),
          {},
          class: "bg-gray-50 border border-gray-100 rounded-xl px-4 py-2.5 text-sm font-medium text-gray-700 focus:ring-2 focus:ring-indigo-500 outline-none" %>

      <%= f.submit "Filter", class: "bg-gray-900 text-white text-sm font-bold px-4 py-2.5 rounded-xl hover:bg-gray-800 transition-colors cursor-pointer" %>

      <% if params[:q].present? || params[:reason].present? %>
        <%= link_to "Clear", dashboard_inventory_movements_path, class: "text-sm font-bold text-gray-400 hover:text-gray-700 transition-colors" %>
      <% end %>
    <% end %>

    <%# Table %>
    <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Date</th>
            <th class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Product / Variant</th>
            <th class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Reason</th>
            <th class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Qty</th>
            <th class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">By</th>
            <th class="px-6 py-4 text-left text-[10px] font-black text-gray-400 uppercase tracking-widest">Note</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @movements.each do |movement| %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-6 py-4 text-xs text-gray-500 whitespace-nowrap">
                <%= movement.created_at.strftime("%d %b %Y, %H:%M") %>
              </td>
              <td class="px-6 py-4">
                <p class="text-sm font-bold text-gray-900"><%= movement.product_variant.product.name %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= movement.product_variant.option_text %></p>
              </td>
              <td class="px-6 py-4">
                <% badge = case movement.reason
                  when "sale"       then { bg: "bg-blue-50",   text: "text-blue-700",   dot: "bg-blue-500" }
                  when "restock"    then { bg: "bg-green-50",  text: "text-green-700",  dot: "bg-green-500" }
                  when "return"     then { bg: "bg-orange-50", text: "text-orange-700", dot: "bg-orange-500" }
                  when "adjustment" then { bg: "bg-purple-50", text: "text-purple-700", dot: "bg-purple-500" }
                  when "damage"     then { bg: "bg-red-50",    text: "text-red-700",    dot: "bg-red-500" }
                  end %>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold <%= badge[:bg] %> <%= badge[:text] %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= badge[:dot] %>"></span>
                  <%= movement.reason.capitalize %>
                </span>
              </td>
              <td class="px-6 py-4">
                <span class="text-sm font-bold <%= movement.quantity > 0 ? 'text-green-600' : 'text-red-600' %>">
                  <%= movement.quantity > 0 ? "+#{movement.quantity}" : movement.quantity %>
                </span>
              </td>
              <td class="px-6 py-4 text-xs text-gray-600">
                <% if movement.user %>
                  <span class="font-medium"><%= movement.user.email_address %></span>
                <% elsif movement.order_item %>
                  <%= link_to "Order ##{movement.order_item.order_id}", dashboard_order_path(movement.order_item.order_id), class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
                <% else %>
                  <span class="text-gray-400">system</span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-xs text-gray-500 max-w-xs truncate">
                <%= movement.note.presence || "—" %>
              </td>
            </tr>
          <% end %>

          <% if @movements.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-16 text-center">
                <div class="w-12 h-12 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl opacity-40">📋</div>
                <p class="text-sm font-bold text-gray-900">No movements yet</p>
                <p class="text-xs text-gray-500 mt-1">Inventory changes will appear here.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-8 flex justify-center pb-12">
      <div class="pagy"><%== @pagy.series_nav %></div>
    </div>
  </div>
</div>
