<div class="max-w-2xl mx-auto">
  <div class="flex items-center gap-4 mb-8">
    <%= link_to dashboard_categories_path, class: "w-10 h-10 bg-gray-100 text-gray-600 rounded-xl flex items-center justify-center hover:bg-gray-200 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
      </svg>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Edit <%= @category.name %></h1>
    </div>
  </div>

  <%= render "form", category: @category %>
</div>
