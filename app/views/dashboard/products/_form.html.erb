<%= form_with model: [:dashboard, product], id: "product-info-form",
  class: "bg-white rounded-2xl border border-gray-200 p-6 space-y-5" do |f| %>
  <h2 class="font-semibold text-gray-900">Product Information</h2>

  <div>
    <%= f.label :name, "Title", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_field :name,
      class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition",
      placeholder: "e.g. Classic T-Shirt" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_area :description, rows: 4,
      class: "w-full border border-gray-300 rounded-lg px-3.5 py-2.5 text-sm focus:ring-2 focus:ring-gray-900 focus:border-transparent outline-none transition resize-none",
      placeholder: "Describe your product..." %>
  </div>

  <div>
    <%= f.label :slug, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-gray-900">
      <span class="bg-gray-50 text-gray-400 text-sm px-3 py-2.5 border-r border-gray-300 select-none">/products/</span>
      <%= f.text_field :slug, class: "flex-1 px-3 py-2.5 text-sm outline-none",
        placeholder: "classic-t-shirt" %>
    </div>
  </div>

  <div class="pt-2" data-controller="image-preview">
    <%= f.label :images, "Product Images", class: "block text-sm font-medium text-gray-700 mb-2.5" %>
    <div class="grid grid-cols-4 gap-4 mb-4" data-image-preview-target="grid">
      <% if product.images.attached? %>
        <% product.images.each do |image| %>
          <div class="relative group aspect-square rounded-xl overflow-hidden border border-gray-200 bg-gray-50" id="image_<%= image.id %>">
            <%= image_tag image.variant(resize_to_limit: [200, 200]), class: "w-full h-full object-cover" %>
            <%= link_to delete_image_dashboard_product_path(product, image_id: image.id),
                data: { turbo_method: :delete, turbo_confirm: "Delete this image?" },
                class: "absolute top-1 right-1 bg-white/90 text-red-500 p-1 rounded-full shadow-sm opacity-0 group-hover:opacity-100 transition-opacity hover:bg-red-50" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% end %>
      
      <label class="aspect-square flex flex-col items-center justify-center border-2 border-dashed border-gray-200 rounded-xl hover:border-indigo-400 hover:bg-indigo-50/30 cursor-pointer transition-all group">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gray-400 group-hover:text-indigo-500 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        <span class="text-[10px] font-medium text-gray-500 group-hover:text-indigo-600">Add Photos</span>
        <%= f.file_field :images, multiple: true, class: "hidden", 
            data: { 
              image_preview_target: "input",
              action: "change->image-preview#preview"
            } %>
      </label>
    </div>
  <div class="pt-4 border-t border-gray-100">
    <%= f.label :collection_ids, "Collections", class: "block text-sm font-medium text-gray-700 mb-3" %>
    <div class="grid grid-cols-2 gap-3">
      <%= f.collection_check_boxes :collection_ids, Collection.all, :id, :name do |b| %>
        <div class="flex items-center gap-3 p-3 border border-gray-100 rounded-xl hover:bg-gray-50 transition-colors">
          <%= b.check_box class: "w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500" %>
          <%= b.label class: "text-xs font-medium text-gray-600 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
