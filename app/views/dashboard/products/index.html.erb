<div class="min-h-screen bg-gray-50/50 pb-12">
  
  <%# Header Section %>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Products</h1>
          <p class="text-sm text-gray-500 mt-1">Manage your inventory, pricing, and variants.</p>
        </div>
        <%= link_to new_dashboard_product_path,
          class: "inline-flex items-center gap-2 bg-gray-900 text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:bg-gray-800 transition-all shadow-sm active:scale-95" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add Product
        <% end %>
      </div>

      <%# Summary Stats %>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">Total Products</p>
          <p class="text-2xl font-bold text-gray-900"><%= @products.count %></p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">Total Inventory</p>
          <p class="text-2xl font-bold text-gray-900"><%= @products.joins(:product_variants).sum(:stock) %></p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">Active Variants</p>
          <p class="text-2xl font-bold text-indigo-600"><%= @products.joins(:product_variants).where(product_variants: { active: true }).count %></p>
        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
          <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">Low Stock Alerts</p>
          <% low_stock = @products.joins(:product_variants).where("stock <= ?", 5).count %>
          <p class="text-2xl font-bold <%= low_stock > 0 ? 'text-red-500' : 'text-gray-900' %>"><%= low_stock %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-8">
    
    <% if @products.any? %>
      <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm">
        
        <%# Filters Bar %>
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
          <div class="flex items-center gap-1">
            <button class="px-3 py-1.5 text-sm font-semibold text-gray-900 bg-white border border-gray-200 rounded-lg shadow-sm">All</button>
            <button class="px-3 py-1.5 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors">Active</button>
            <button class="px-3 py-1.5 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors">Draft</button>
          </div>
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" placeholder="Filter products..." class="pl-9 pr-4 py-2 bg-white border border-gray-200 rounded-xl text-sm focus:ring-2 focus:ring-indigo-500 outline-none w-64 transition-all" />
          </div>
        </div>

        <%# Table View %>
        <table class="w-full">
          <thead class="bg-gray-50/50 border-b border-gray-100">
            <tr>
              <th class="w-16 px-6 py-4"></th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Product</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Status</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Inventory</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Price Range</th>
              <th class="px-6 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @products.each do |product| %>
              <tr class="group hover:bg-gray-50/50 transition-colors">
                <td class="px-6 py-4">
                  <div class="w-12 h-12 rounded-xl border border-gray-100 overflow-hidden bg-gray-50 shadow-sm flex items-center justify-center shrink-0">
                    <% if product.images.attached? %>
                      <%= image_tag product.images.first.variant(resize_to_limit: [100, 100]), class: "w-full h-full object-cover" %>
                    <% else %>
                      <span class="text-xl">📦</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <%= link_to edit_dashboard_product_path(product), class: "block group" do %>
                    <span class="text-sm font-bold text-gray-900 group-hover:text-indigo-600 transition-colors"><%= product.name %></span>
                    <span class="block text-xs text-gray-400 mt-0.5"><%= product.product_variants.count %> variant(s)</span>
                  <% end %>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                    <%= product.status == 'active' ? 'bg-green-50 text-green-700 border border-green-100' : 'bg-gray-50 text-gray-500 border border-gray-100' %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= product.status == 'active' ? 'bg-green-500' : 'bg-gray-400' %>"></span>
                    <%= product.status&.capitalize || 'Draft' %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <% total_stock = product.product_variants.sum(:stock) %>
                  <div class="flex items-center gap-2">
                    <div class="w-24 h-1.5 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full <%= total_stock > 10 ? 'bg-indigo-500' : 'bg-red-500' %>" style="width: <%= [total_stock * 2, 100].min %>%"></div>
                    </div>
                    <span class="text-xs font-semibold <%= total_stock > 10 ? 'text-gray-600' : 'text-red-600' %>"><%= total_stock %></span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <% prices = product.product_variants.pluck(:price).compact %>
                  <% if prices.any? %>
                    <span class="text-sm font-bold text-gray-900">
                      <% if prices.min == prices.max %>
                        Rp <%= number_with_delimiter(prices.min.to_i) %>
                      <% else %>
                        Rp <%= number_with_delimiter(prices.min.to_i) %>+
                      <% end %>
                    </span>
                  <% else %>
                    <span class="text-xs text-gray-400">—</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                    <%= link_to edit_dashboard_product_path(product), class: "p-2 hover:bg-white rounded-lg border border-transparent hover:border-gray-200 hover:shadow-sm text-gray-500 hover:text-indigo-600 transition-all" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                      </svg>
                    <% end %>
                    <%= button_to dashboard_product_path(product), method: :delete, data: { turbo_confirm: "Delete product?" }, class: "p-2 hover:bg-white rounded-lg border border-transparent hover:border-red-100 hover:shadow-sm text-gray-400 hover:text-red-500 transition-all" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

      </div>
    <% else %>
      <%# Enhanced Empty State %>
      <div class="bg-white border-2 border-dashed border-gray-200 rounded-3xl py-32 text-center">
        <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-5xl">🛍️</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">No products found</h2>
        <p class="text-gray-500 max-w-sm mx-auto mb-8">Start growing your inventory by adding your first product with its variants and pricing.</p>
        <%= link_to new_dashboard_product_path,
          class: "inline-flex items-center gap-2 bg-indigo-600 text-white text-sm font-bold px-8 py-3.5 rounded-2xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100 active:scale-95" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Add First Product
        <% end %>
      </div>
    <% end %>

  </div>
</div>
