<div class="pb-12">
  
  <%# Header Section %>
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-6 py-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Orders</h1>
          <p class="text-sm text-gray-500 mt-1">Track and manage customer purchases.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-8">
    
    <% if @orders.any? %>
      <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm">
        
        <table class="w-full">
          <thead class="bg-gray-50/50 border-b border-gray-100">
            <tr>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Order ID</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Customer</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Date</th>
              <th class="text-left text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4">Status</th>
              <th class="text-right text-xs font-bold text-gray-400 uppercase tracking-widest px-6 py-4 pr-12">Total</th>
              <th class="px-6 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @orders.each do |order| %>
              <tr class="group hover:bg-gray-50/50 transition-colors">
                <td class="px-6 py-4">
                  <span class="text-sm font-bold text-gray-900">#<%= order.id.to_s.rjust(5, '0') %></span>
                </td>
                <td class="px-6 py-4">
                  <div class="flex flex-col">
                    <span class="text-sm font-semibold text-gray-900"><%= order.customer_name %></span>
                    <span class="text-xs text-gray-400"><%= order.customer_email %></span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="text-sm text-gray-600"><%= order.created_at.strftime("%b %d, %Y") %></span>
                </td>
                <td class="px-6 py-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider
                    <%= case order.status
                        when 'pending' then 'bg-yellow-50 text-yellow-700 border border-yellow-100'
                        when 'paid' then 'bg-blue-50 text-blue-700 border border-blue-100'
                        when 'shipped' then 'bg-indigo-50 text-indigo-700 border border-indigo-100'
                        when 'completed' then 'bg-green-50 text-green-700 border border-green-100'
                        else 'bg-gray-50 text-gray-500 border border-gray-100'
                        end %>">
                    <%= order.status.capitalize %>
                  </span>
                </td>
                <td class="px-6 py-4 text-right pr-12">
                  <span class="text-sm font-bold text-gray-900">Rp <%= number_with_delimiter(order.total_price.to_i) %></span>
                </td>
                <td class="px-6 py-4 text-right">
                  <%= link_to dashboard_order_path(order), class: "text-sm font-bold text-indigo-600 hover:text-indigo-800 transition-colors" do %>
                    Details →
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>

      </div>
    <% else %>
      <div class="bg-white border-2 border-dashed border-gray-200 rounded-3xl py-32 text-center">
        <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <span class="text-5xl">📝</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-2">No orders yet</h2>
        <p class="text-gray-500 max-w-sm mx-auto">When customers buy your products, they'll appear here.</p>
      </div>
    <% end %>

    <div class="mt-12 flex justify-center">
      <%== @pagy.series_nav %>
    </div>
  </div>
</div>
