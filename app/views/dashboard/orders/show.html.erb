<div class="pb-24">
  
  <%# Header %>
  <div class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <%= link_to dashboard_orders_path, class: "text-gray-400 hover:text-gray-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        <% end %>
        <h1 class="text-lg font-bold text-gray-900">Order #<%= @order.id.to_s.rjust(5, '0') %></h1>
      </div>
      
      <div class="flex items-center gap-3">
        <%= form_with model: [:dashboard, @order], class: "flex items-center gap-2" do |f| %>
          <%= f.select :status, Order.statuses.keys.map { |s| [s.capitalize, s] }, {}, 
              class: "text-sm border border-gray-200 rounded-lg px-3 py-1.5 focus:ring-2 focus:ring-indigo-500 outline-none" %>
          <%= f.submit "Update Status", class: "bg-gray-900 text-white text-sm font-semibold px-4 py-1.5 rounded-lg hover:bg-gray-800 transition-colors cursor-pointer" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 mt-8 grid grid-cols-1 md:grid-cols-3 gap-8">
    
    <%# Main Info %>
    <div class="md:col-span-2 space-y-6">
      
      <%# Items Card %>
      <div class="bg-white border border-gray-200 rounded-3xl overflow-hidden shadow-sm">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50/50">
          <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest">Order Items</h2>
        </div>
        <div class="divide-y divide-gray-100">
          <% @order_items.each do |item| %>
            <div class="px-6 py-4 flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center overflow-hidden">
                  <% if item.product_variant.product.images.attached? %>
                    <%= image_tag item.product_variant.product.images.first.variant(resize_to_limit: [100, 100]), class: "w-full h-full object-cover" %>
                  <% else %>
                    <span class="text-xl">📦</span>
                  <% end %>
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900"><%= item.product_variant.product.name %></p>
                  <p class="text-xs text-gray-500"><%= item.product_variant.option_text %></p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-sm font-bold text-gray-900">Rp <%= number_with_delimiter(item.unit_price.to_i) %></p>
                <p class="text-xs text-gray-400">Qty: <%= item.quantity %></p>
              </div>
            </div>
          <% end %>
        </div>
        <div class="bg-gray-50/50 px-6 py-4 border-t border-gray-100 flex justify-between items-center">
          <span class="text-sm font-bold text-gray-500">Total Price</span>
          <span class="text-xl font-black text-gray-900">Rp <%= number_with_delimiter(@order.total_price.to_i) %></span>
        </div>
      </div>

    </div>

    <%# Sidebar: Customer Info %>
    <div class="space-y-6">
      <div class="bg-white border border-gray-200 rounded-3xl p-6 shadow-sm">
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest mb-6">Customer Details</h2>
        
        <div class="space-y-6">
          <div>
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Name</p>
            <p class="text-sm font-semibold text-gray-900"><%= @order.customer_name %></p>
          </div>
          <div>
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Contact</p>
            <p class="text-sm font-semibold text-gray-900"><%= @order.customer_email %></p>
            <p class="text-xs text-gray-500 mt-0.5"><%= @order.customer_phone %></p>
          </div>
          <div class="pt-6 border-t border-gray-100">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1">Shipping Address</p>
            <p class="text-sm text-gray-600 leading-relaxed"><%= @order.shipping_address %></p>
          </div>
        </div>
      </div>
      
      <div class="bg-indigo-600 rounded-3xl p-6 text-white shadow-xl shadow-indigo-100">
        <h3 class="text-xs font-bold uppercase tracking-widest opacity-80 mb-2">Order Summary</h3>
        <p class="text-xs leading-relaxed opacity-90">Customer chose Standard Shipping. Expected delivery within 3-5 business days after shipping.</p>
      </div>
    </div>

  </div>
</div>
