<% content_for :title, "My Wishlist" %>

<div class="max-w-7xl mx-auto px-6 py-12">
  <div class="mb-10">
    <h1 class="text-4xl font-bold text-gray-900">My Wishlist</h1>
    <p class="text-gray-500 mt-2"><%= @wishlist_items.size %> saved items</p>
  </div>

  <% if @wishlist_items.empty? %>
    <div class="py-24 text-center">
      <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900">Your wishlist is empty</h3>
      <p class="text-gray-500 mt-2 mb-8">Save items you love and come back to them later.</p>
      <%= link_to "Browse Products", products_path, class: "inline-block bg-gray-900 text-white px-8 py-3 rounded-xl font-bold hover:bg-gray-800 transition-colors" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12">
      <% @wishlist_items.each do |item| %>
        <% product = item.product %>
        <div class="group relative">
          <div class="aspect-[4/5] w-full overflow-hidden rounded-2xl bg-gray-100 group-hover:shadow-xl transition-all duration-500">
            <% if product.images.attached? %>
              <%= image_tag product.images.first.variant(resize_to_limit: [600, 800]),
                    class: "h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-700" %>
            <% else %>
              <div class="h-full w-full flex items-center justify-center bg-gray-50 text-5xl opacity-20">📦</div>
            <% end %>

            <div class="absolute top-3 right-3">
              <%= render "shared/wishlist_button", product: product %>
            </div>
          </div>

          <div class="mt-4">
            <h3 class="text-sm font-semibold text-gray-700">
              <%= link_to product_path(product) do %>
                <span aria-hidden="true" class="absolute inset-0"></span>
                <%= product.name %>
              <% end %>
            </h3>
            <% prices = product.product_variants.map(&:price).compact %>
            <p class="text-sm font-bold text-gray-900 mt-1">
              <% if prices.any? %>
                Rp <%= number_with_delimiter(prices.min.to_i) %>
              <% else %>
                &mdash;
              <% end %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
