<% content_for :title, "My Addresses" %>

<div class="bg-gray-50/50 min-h-screen pb-24">
  <div class="max-w-2xl mx-auto px-6 py-12">

    <div class="flex items-center justify-between mb-8">
      <div>
        <%= link_to account_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-gray-500 hover:text-gray-900 transition-colors mb-3" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          My Account
        <% end %>
        <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Saved Addresses</h1>
      </div>
      <%= link_to new_address_path, class: "flex items-center gap-2 bg-gray-900 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-gray-800 transition-all" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Address
      <% end %>
    </div>

    <% if @addresses.any? %>
      <div class="space-y-4">
        <% @addresses.each do |address| %>
          <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <p class="text-sm font-bold text-gray-900"><%= address.full_name %></p>
                  <% if address.is_default? %>
                    <span class="px-2 py-0.5 bg-indigo-50 text-indigo-600 text-[10px] font-bold uppercase tracking-wider rounded-full border border-indigo-100">Default</span>
                  <% end %>
                </div>
                <p class="text-sm text-gray-500"><%= address.phone %></p>
                <p class="text-sm text-gray-500 mt-1"><%= address.full_address %></p>
              </div>

              <div class="flex items-center gap-2 flex-shrink-0">
                <% unless address.is_default? %>
                  <%= button_to set_default_address_path(address), method: :patch,
                        class: "text-xs font-semibold text-indigo-600 hover:text-indigo-800 transition-colors" do %>
                    Set Default
                  <% end %>
                <% end %>
                <%= link_to edit_address_path(address), class: "text-xs font-semibold text-gray-500 hover:text-gray-900 transition-colors" do %>
                  Edit
                <% end %>
                <%= button_to address_path(address), method: :delete,
                      class: "text-xs font-semibold text-red-400 hover:text-red-600 transition-colors",
                      data: { turbo_confirm: "Remove this address?" } do %>
                  Remove
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-3xl border border-gray-100 shadow-sm py-16 text-center">
        <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-sm font-semibold text-gray-500">No saved addresses yet.</p>
        <%= link_to "Add your first address", new_address_path, class: "inline-block mt-3 text-sm font-bold text-indigo-600 hover:text-indigo-800" %>
      </div>
    <% end %>

  </div>
</div>
