<% content_for :title, "Edit Profile" %>

<div class="bg-gray-50/50 min-h-screen pb-24">
  <div class="max-w-lg mx-auto px-6 py-12">

    <div class="mb-8">
      <%= link_to account_path, class: "inline-flex items-center gap-2 text-sm font-semibold text-gray-500 hover:text-gray-900 transition-colors mb-6" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        My Account
      <% end %>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Edit Profile</h1>
    </div>

    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-8">
      <%= form_with model: Current.user, url: account_path, method: :patch do |f| %>
        <% if Current.user.errors.any? %>
          <div class="mb-6 p-4 bg-red-50 rounded-2xl border border-red-100">
            <ul class="text-sm text-red-600 space-y-1">
              <% Current.user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :first_name, class: "block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2" %>
              <%= f.text_field :first_name,
                    class: "w-full px-4 py-3 border border-gray-200 rounded-xl text-sm font-medium text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all",
                    placeholder: "John" %>
            </div>
            <div>
              <%= f.label :last_name, class: "block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2" %>
              <%= f.text_field :last_name,
                    class: "w-full px-4 py-3 border border-gray-200 rounded-xl text-sm font-medium text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all",
                    placeholder: "Doe" %>
            </div>
          </div>

          <div>
            <%= f.label :email_address, "Email", class: "block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2" %>
            <input type="email" value="<%= Current.user.email_address %>" disabled
                   class="w-full px-4 py-3 border border-gray-100 rounded-xl text-sm font-medium text-gray-400 bg-gray-50 cursor-not-allowed">
            <p class="text-xs text-gray-400 mt-1.5">Email cannot be changed.</p>
          </div>

          <%= f.submit "Save Changes",
                class: "w-full bg-gray-900 text-white py-4 rounded-2xl font-bold hover:bg-gray-800 transition-all shadow-lg active:scale-95 cursor-pointer mt-2" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
